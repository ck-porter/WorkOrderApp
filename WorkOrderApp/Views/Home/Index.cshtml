@model WorkOrderApp.Services.WeatherResult

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

@if (Model != null)
{
    <div class="card mt-4 p-3" style="max-width: 400px; margin: 0 auto;">
        <h4 class="mb-3">Current Weather</h4>
        <div class="d-flex align-items-center justify-content-center">
            @if (Model?.Weather?.Length > 0)
            {
                <img src="@($"https://openweathermap.org/img/wn/{Model.Weather[0].Icon}@2x.png")" alt="Weather icon" />
            }
            <div class="ms-3 text-start">
                <h5 class="mb-1">@Model.Main.Temp°C</h5>
                <p class="text-muted mb-0">@Model.Weather[0].Description</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning mt-4">
        Weather data unavailable.
    </div>
}

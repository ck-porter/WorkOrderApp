@model WorkOrderApp.Models.WorkOrder

@{
    ViewData["Title"] = "Work Order Details";
}

<div class="container">
    <h2 class="fw-bold mb-4" style="color: var(--avc-green);">Work Order Details</h2>
    <div class="card shadow-sm p-4 mb-4">
        <h4 class="fw-bold">@Model.Title</h4>
        <p class="text-muted">@Model.Description</p>
        <div class="row mt-3">
            <div class="col-md-4">
                <strong>Status:</strong>
                <span class="badge bg-info text-dark">@Model.Status</span>
            </div>
            <div class="col-md-4">
                <strong>Priority:</strong>
                <span class="badge bg-danger">@Model.Priority</span>
            </div>
            <div class="col-md-4">
                <strong>Assigned To:</strong>
                @Model.AssignedToUser?.Email
            </div>
        </div>
    </div>

    <div class="card shadow-sm p-4 mb-4">
        <h5 class="fw-bold mb-3">Activity Log</h5>
        @if (Model.Logs?.Any() == true)
        {
            <ul class="list-group">
                @foreach (var log in Model.Logs.OrderByDescending(l => l.Timestamp))
                {
                    <li class="list-group-item">
                        <strong>@log.Action</strong>
                        by @log.PerformedByUser?.Email
                        <span class="text-muted float-end">@log.Timestamp</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted">No activity recorded.</p>
        }
    </div>
    <div class="d-flex gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary px-4">Back</a>
    </div>
</div>

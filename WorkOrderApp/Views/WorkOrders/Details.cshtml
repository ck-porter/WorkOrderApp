@model WorkOrderApp.Models.WorkOrder

@{
    ViewData["Title"] = "Details";
}

<h1>Work Order Details</h1>
<div class="card mb-4">
    <div class="card-body">
        <h4>@Model.Title</h4>
        <p>@Model.Description</p>
        <p><strong>Status: </strong>@Model.Status</p>
        <p><strong>Priority: </strong>@Model.Priority</p>
        <p><strong>Assigned To: </strong>@Model.AssignedToUserId</p>
        <p><strong>Created At: </strong>@Model.CreatedAt</p>
    </div>
</div>
<h4>Activity Log</h4>
@if (Model.Logs == null || !Model.Logs.Any())
{
    <p>No activity logs available.</p>
}
else
{
   <ul class="list-group">
        @foreach (var log in Model.Logs.OrderByDescending(l => l.Timestamp))
        {
            <li class="list-group-item">
                <strong>@log.Timestamp:</strong> @log.Action
                @if (!string.IsNullOrEmpty(log.AssignedToUserId))
                {
                    <span> ->@log.AssignedToUserId</span>
                }
                <div class="text-muted">
                    by @log.PerformedByUser?.Email
                </div>
            </li>
        }      

   </ul>
}
)

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>

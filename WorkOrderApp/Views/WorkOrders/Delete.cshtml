@model WorkOrderApp.Models.WorkOrder

@{
    ViewData["Title"] = "Delete Work Order";
}

<div class="container">
    <h2 class="fw-bold mb-4" style="color: var(--avc-green);">Delete Work Order</h2>
    <div class="card shadow-sm p-4 mb-4 border-danger">
        <h4 class="fw-bold text-danger mb-3">Are you sure you want to delete this work order?</h4>
        <p class="text-muted">This action cannot be undone.</p>
        <div class="row mt-3">
            <div class="col-md-4">
                <strong>Title:</strong>
                <div>@Model.Title</div>
            </div>
            <div class="col-md-4">
                <strong>Status:</strong>
                <span class="badge bg-info text-dark">@Model.Status</span>
            </div>
            <div class="col-md-4">
                <strong>Priority:</strong>
                <span class="badge bg-danger">@Model.Priority</span>
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-md-6">
                <strong>Description:</strong>
                <p class="text-muted">@Model.Description</p>
            </div>
            <div class="col-md-6">
                <strong>Assigned To:</strong>
                <div>@Model.AssignedToUser?.Email</div>
            </div>
        </div>
    </div>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-danger px-4">Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
    </form>
</div>
